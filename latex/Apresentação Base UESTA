    \begin{frame}
    \frametitle{Meta Nacional 1}
    \framesubtitle{Julgar mais processos que os distribuídos}
    \begin{justify}\textbf{Julgar} quantidade \textbf{maior} de processos de conhecimento do que os distribuídos \textbf{de 20/12/2025 a 19/12/2026}, excluídos suspensos e sobrestados.\end{justify}
\begin{table}[]
\begin{tabular}{cccc}
\hline
\textbf{Ano}  & \textbf{1G} & \textbf{STM} & \textbf{JMU} \\ \hline
\textbf{2024} &  98,34\%           &  105,62\%            &   100,21\%           \\
\textbf{2025} & 95,65\%     & 95,10\%      & 95,48\%      \\ \hline
\end{tabular}
\end{table}\begin{justify}
    \begin{itemize}
    \item[\CheckmarkBold] \textbf{2024}: Meta cumprida no geral.
    \item \textbf{STM}: Desempenho acima da meta, com julgamento superior à distribuição.
    \item[\XSolidBold] \textbf{2025}: Desempenho abaixo da meta em todos os segmentos.
    \item \textbf{2026}: Foco em ações para recuperar o cumprimento da meta.
  \end{itemize}\end{justify}
  \end{frame}

  \begin{frame}
    \frametitle{Meta Nacional 2}
    \framesubtitle{Julgar processos mais antigos}
    
     \begin{justify}\textbf{Julgar todos} os procesos de conhecimento pendentes de julgamento \textbf{há 5 anos} (2021) \textbf{ou mais}; \textbf{95\%} dos processos distribuídos até \textbf{31/12/2023} nas \textbf{Auditorias} e \textbf{99\%} dos processos distribuídos até \textbf{31/12/2024} no \textbf{STM}.\end{justify}
\begin{table}[]
\begin{tabular}{cccc}
\hline
\textbf{Ano}  & \textbf{1G} & \textbf{STM} & \textbf{JMU} \\ \hline
\textbf{2024} &   103,51\%          & 101,01\%             & Cumpriu            \\
\textbf{2025} & 103,23\%     & 101,65\%      & 102.65\%      \\ \hline
\end{tabular}
\end{table}
    \begin{itemize}
    \item[\CheckmarkBold] \textbf{2024}: Meta superada em todos os segmentos.
    \item[\CheckmarkBold]  \textbf{2025}: Manutenção do cumprimento com resultados estáveis.
    \item \textbf{STM}: Percentual acima do patamar mínimo exigido.
    \item \textbf{JMU}: Desempenho consistente acima de 100\%.
  \end{itemize}
  \end{frame}

    \begin{frame}
    \frametitle{Meta Nacional 4}
    \framesubtitle{Priorizar processos crimes contra a Admnistração Pública}
    
     \begin{justify}\textbf{Identificar e julgar} até 31/12/2026, \textbf{95\%} dos processos da meta distribuídos até \textbf{31/12/2023} nas Auditorias e \textbf{99\%} dos processos da meta \textbf{distribuídos até 31/12/2024 no STM}. \end{justify}
\begin{table}[]
\begin{tabular}{cccc}
\hline
\textbf{Ano}  & \textbf{1G} & \textbf{STM} & \textbf{JMU} \\ \hline
\textbf{2024} &   103,47\%          & 101,01\%             & Cumpriu            \\
\textbf{2025} & 102,34\%     & 101,01\%      & Cumpriu      \\ \hline
\end{tabular}
\end{table}
\begin{itemize}
  \item[\CheckmarkBold] \textbf{2024}: Meta superada em todos os segmentos avaliados.
  \item[\CheckmarkBold] \textbf{2025}: Manutenção do cumprimento da meta, com resultados estáveis.
  \item \textbf{STM}: Percentual consistentemente acima do patamar mínimo exigido.
  \item \textbf{JMU}: Desempenho consistente, com índices superiores a 100\%.
\end{itemize}
  \end{frame}

