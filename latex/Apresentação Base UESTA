    \begin{frame}
    \frametitle{Atribuições}
       \framesubtitle{Unidade de Apoio Especializado - Estatística}

\begin{justify}

A unidade atua na \textbf{análise, tratamento e validação dos dados estatísticos da JMU}, produzindo \textbf{estudos, relatórios e painéis}, coordenando o \textbf{saneamento dos dados judiciais}, propondo \textbf{métodos e controles estatísticos} da produção judiciária, atendendo \textbf{demandas internas e externas}, validando remessas ao CNJ e prestando \textbf{suporte técnico às demais unidades}.

\end{justify}

\end{frame}

